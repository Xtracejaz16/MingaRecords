
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// --- Enums ---

enum BeatStatus {
  draft
  pending_audio
  processing
  ready
  published
  sold
  archived
  deleted
}

enum LicenseType {
  BASIC
  PREMIUM
  EXCLUSIVE
}

// --- Models ---

// La tabla de usuarios. Cada registro es una persona que se registró.
model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  alias              String
  role               String
  avatarUrl          String?
  bio                String?
  beatmakerGenre     String?
  artistName         String?
  emailVerified      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  // Un usuario puede tener muchos refresh tokens (uno por dispositivo).
  refreshTokens      RefreshToken[]
  // Un usuario puede tener muchos tokens de verificación (aunque normalmente uno solo).
  verificationTokens VerificationToken[]
  // Beats que este usuario produce.
  producedBeats      Beat[]              @relation("ProducerBeats")
  // Beats que este usuario compró.
  buyerBeats         Beat[]              @relation("BuyerBeats")
}

// La tabla de refresh tokens. Cada fila es una sesión activa en un dispositivo.
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  // Relación: este refresh token pertenece a un usuario.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// La tabla de tokens de verificación de email.
// Se crea al registrarse. Se marca como usado (usedAt) cuando el usuario confirma su email.
// El token se guarda hasheado (SHA-256) por seguridad.
model VerificationToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  usedAt     DateTime?
  // Relación: este token pertenece a un usuario.
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// La tabla de géneros musicales.
model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

// La tabla de beats. Cada registro es un beat que un productor sube para vender.
model Beat {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?
  priceCents  Int
  genre       String?
  bpm         Int?
  key         String?
  tags        String[]
  audioUrl    String?
  coverUrl    String?
  previewUrl  String?
  streamUrl   String?
  playsCount  Int         @default(0)
  salesCount  Int         @default(0)
  status      BeatStatus  @default(draft)
  publishedAt DateTime?
  deletedAt   DateTime?
  producerId  String
  producer    User        @relation("ProducerBeats", fields: [producerId], references: [id], onDelete: Cascade)
  buyerId     String?
  buyer       User?       @relation("BuyerBeats", fields: [buyerId], references: [id], onDelete: SetNull)
  licenses    License[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// La tabla de licencias. Cada registro es un tipo de licencia para un beat específico.
model License {
  id         String      @id @default(uuid())
  type       LicenseType
  priceCents Int
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  beatId     String
  beat       Beat        @relation(fields: [beatId], references: [id], onDelete: Cascade)

  @@unique([beatId, type])
}
