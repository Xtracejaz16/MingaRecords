

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
// La tabla de usuarios. Cada registro es una persona que se registró.
model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  alias              String
  role               String
  emailVerified      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  // Un usuario puede tener muchos refresh tokens (uno por dispositivo).
  refreshTokens      RefreshToken[]
  
  // Un usuario puede tener muchos tokens de verificación (aunque normalmente uno solo).
  verificationTokens VerificationToken[]
  // Beats que este usuario vende.
  sellerBeats        Beat[]              @relation("SellerBeats")
  // Beats que este usuario compró.
  buyerBeats         Beat[]              @relation("BuyerBeats")
}
// La tabla de refresh tokens. Cada fila es una sesión activa en un dispositivo.
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  // Relación: este refresh token pertenece a un usuario.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// La tabla de tokens de verificación de email.
// Se crea al registrarse y se borra cuando el usuario confirma su email.
model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  // Relación: este token pertenece a un usuario.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// La tabla de beats. Cada registro es un beat que un artista sube para vender.
model Beat {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Float
  isSold      Boolean  @default(false)
  audioUrl    String
  coverUrl    String
  sellerId    String
  seller      User     @relation("SellerBeats", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId     String?
  buyer       User?    @relation("BuyerBeats", fields: [buyerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

